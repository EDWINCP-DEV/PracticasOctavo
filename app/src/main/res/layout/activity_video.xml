<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F0F2F5"
    tools:context=".VideoActivity">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="C1_AF04 - VideoView"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardVideo"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnRaw"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="RECURSO RAW"
        android:onClick="reproducirRaw"
        android:drawableStart="@android:drawable/ic_menu_slideshow"
        android:paddingStart="16dp"
        android:backgroundTint="#3949AB"
        android:textColor="@android:color/white"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardVideo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <Button
        android:id="@+id/btnStreaming"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="STREAMING (URL)"
        android:onClick="reproducirStreaming"
        android:drawableStart="@android:drawable/ic_menu_share"
        android:paddingStart="16dp"
        android:backgroundTint="#1E88E5"
        android:textColor="@android:color/white"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRaw"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnInterno"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="ALMACENAMIENTO INTERNO"
        android:onClick="reproducirInterno"
        android:drawableStart="@android:drawable/ic_menu_save"
        android:paddingStart="16dp"
        android:backgroundTint="#039BE5"
        android:textColor="@android:color/white"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnStreaming"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>